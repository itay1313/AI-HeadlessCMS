# ── Storyblok ─────────────────────────────────────────────
# Space ID (numeric) — visible in your space URL
STORYBLOK_SPACE_ID=

# Personal Access Token (Management API). Account settings → Account.
STORYBLOK_MANAGEMENT_TOKEN=

# Public delivery token (read published content)
NEXT_PUBLIC_STORYBLOK_ACCESS_TOKEN=

# Preview delivery token (read draft content) — server-side only
STORYBLOK_PREVIEW_TOKEN=

# Optional: shown to "Open in Storyblok" link in the builder UI
NEXT_PUBLIC_STORYBLOK_SPACE_ID=

# Secret matched by /api/draft when Storyblok opens the Visual Editor
STORYBLOK_PREVIEW_SECRET=change-me

# Optional: secret matched by /api/revalidate for SB published webhook
STORYBLOK_WEBHOOK_SECRET=change-me

# ── AI ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Builder access ────────────────────────────────────────
# Shared password for the /builder dashboard + write APIs
BUILDER_SHARED_SECRET=change-me

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
